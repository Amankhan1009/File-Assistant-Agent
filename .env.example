# =============================================================================
# Groq API Configuration
# =============================================================================

# Required: API key used by langchain-groq to authenticate with Groq.
GROQ_API_KEY=your_groq_api_key_here


# =============================================================================
# LLM Configuration
# =============================================================================

# Optional: Groq model used by the File Assistant.
GROQ_MODEL=openai/gpt-oss-120b


# =============================================================================
# Workspace Configuration
# =============================================================================

# Optional: Relative path to the restricted filesystem workspace.
# The path must remain inside the project directory.
WORKSPACE_ROOT=workspace


# =============================================================================
# Checkpoint Persistence Configuration
# =============================================================================

# Optional: checkpoint backend used by LangGraph.
# Supported values: sqlite, postgres
CHECKPOINT_BACKEND=sqlite

# Required only when CHECKPOINT_BACKEND=postgres.
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_URL=
